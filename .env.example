# --- Site ---
# Canonical URL, used for metadata, OG tags, sitemap & robots.
NEXT_PUBLIC_SITE_URL=https://aurum.vercel.app

# --- Contact / Inquiry routing ---
# WhatsApp number in international format, digits only (e.g. 233200000000)
NEXT_PUBLIC_WHATSAPP_NUMBER=233200000000
# Email that quote requests are forwarded to
NEXT_PUBLIC_INQUIRY_EMAIL=sales@aurumbullion.example

# --- Quote email delivery (optional) ---
# If set, quote requests are emailed via Resend (https://resend.com).
# Without it, requests are logged server-side and the WhatsApp link still works.
RESEND_API_KEY=
# Verified sender; defaults to Resend's shared onboarding address for testing.
RESEND_FROM="Aurum <onboarding@resend.dev>"

# --- Live gold price feed (optional) ---
# If set, the /api/gold-price route will use this provider. Without it the
# route returns a realistic simulated spot price so the ticker always works.
# Example provider: https://www.goldapi.io
GOLD_API_KEY=

# --- Payments (PLACEHOLDER) ---
# The current checkout is a mock. Swap in a precious-metals / high-risk
# friendly provider before going live. See app/api/checkout/route.ts.
PAYMENT_PROVIDER=mock
