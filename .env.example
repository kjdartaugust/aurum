# --- Site ---
# Canonical URL, used for metadata, OG tags, sitemap & robots.
NEXT_PUBLIC_SITE_URL=https://aurum-ten-opal.vercel.app

# --- Contact / Inquiry routing ---
# WhatsApp number in international format, digits only (e.g. 233200000000)
NEXT_PUBLIC_WHATSAPP_NUMBER=233200000000
# Email that quote requests are forwarded to
NEXT_PUBLIC_INQUIRY_EMAIL=sales@aurumbullion.example

# --- Quote email delivery (optional) ---
# If set, quote requests are emailed via Resend (https://resend.com).
# Without it, requests are logged server-side and the WhatsApp link still works.
RESEND_API_KEY=
# Verified sender; defaults to Resend's shared onboarding address for testing.
RESEND_FROM="Aurum <onboarding@resend.dev>"

# --- Live gold price feed ---
# The ticker pulls LIVE data by default from the free, keyless gold-api.com —
# no setup required. Optionally set a goldapi.io key for richer data (it also
# returns its own daily change). If every source fails, the route falls back to
# a realistic simulated price so the ticker never breaks.
# Get a key (optional): https://www.goldapi.io
GOLD_API_KEY=

# --- Order storage (optional, recommended for production) ---
# Create a KV store in the Vercel dashboard (Storage tab) and link it to this
# project — Vercel injects these two automatically. Without them, orders are
# kept in memory (fine for dev / low volume, but not durable across instances).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Analytics (optional, privacy-friendly) ---
# Set to your site domain to enable cookieless Plausible analytics (no consent
# banner required). Leave empty to disable analytics. Alternatives: Vercel Web
# Analytics, Fathom.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- Payments ---
# Provider is pluggable via lib/payments.ts. Bullion is high-risk, so most
# mainstream card processors decline it. Set PAYMENT_PROVIDER to one of:
#   mock     -> no real charge (default; dev/demo)
#   paystack -> cards + mobile money (best for Ghana/Nigeria) [recommended]
#   coinbase -> crypto, international
#   stripe   -> cards, but Stripe restricts bullion — use as backup only
PAYMENT_PROVIDER=mock

# Paystack (PAYMENT_PROVIDER=paystack) — from dashboard.paystack.com
PAYSTACK_SECRET_KEY=
# Currency your Paystack account is set up for. A Ghana account = GHS,
# Nigeria = NGN, etc. Must be a currency your account supports (default GHS).
PAYSTACK_CURRENCY=GHS
# Prices are shown in USD and converted to GHS at charge time using a LIVE FX
# rate (open.er-api.com). This value is only a FALLBACK used if the live lookup
# is unreachable. Ignored if PAYSTACK_CURRENCY=USD.
PAYSTACK_USD_TO_GHS=15.5

# Coinbase Commerce (PAYMENT_PROVIDER=coinbase)
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=

# Stripe (PAYMENT_PROVIDER=stripe) — ⚠️ verify bullion is allowed on your account
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
